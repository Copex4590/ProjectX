#!/bin/sh
set -e

if [ -f /usr/share/debconf/confmodule ]; then
    . /usr/share/debconf/confmodule
    db_version 2.0
fi

desktop_shortcut_enabled() {
    if [ "${PROJECTX_NO_DESKTOP:-0}" = "1" ]; then
        return 1
    fi
    if db_get projectx/desktop-shortcut 2>/dev/null; then
        [ "$RET" = "true" ]
        return
    fi
    return 1
}

launch_after_install_enabled() {
    if [ "${PROJECTX_NO_LAUNCH:-0}" = "1" ]; then
        return 1
    fi
    if db_get projectx/launch-after-install 2>/dev/null; then
        [ "$RET" = "true" ]
        return
    fi
    return 1
}

refresh_desktop_integration() {
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database /usr/share/applications 2>/dev/null || true
    fi
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
    fi
}

installing_user_home() {
    user="$1"
    if [ -z "$user" ] || [ "$user" = "root" ]; then
        return 1
    fi
    getent passwd "$user" | cut -d: -f6
}

user_desktop_dir() {
    user="$1"
    home="$2"
    if [ -z "$home" ] || [ ! -d "$home" ]; then
        return 1
    fi
    if [ -f "$home/.config/user-dirs.dirs" ]; then
        # shellcheck disable=SC1090
        . "$home/.config/user-dirs.dirs"
        eval "dir=\$XDG_DESKTOP_DIR"
        if [ -n "${dir:-}" ]; then
            echo "$dir"
            return 0
        fi
    fi
    echo "$home/Desktop"
}

create_desktop_shortcut() {
    user="$1"
    home="$(installing_user_home "$user")"
    desktop_dir="$(user_desktop_dir "$user" "$home")"
    if [ -z "$desktop_dir" ] || [ ! -d "$desktop_dir" ]; then
        return 0
    fi
    shortcut="${desktop_dir}/Project X.desktop"
    cp /usr/share/applications/projectx.desktop "$shortcut"
    chown "$user:$user" "$shortcut" 2>/dev/null || true
    chmod +x "$shortcut" 2>/dev/null || true
}

remove_desktop_shortcut() {
    user="$1"
    home="$(installing_user_home "$user")"
    desktop_dir="$(user_desktop_dir "$user" "$home")"
    if [ -n "$desktop_dir" ]; then
        rm -f "${desktop_dir}/Project X.desktop"
    fi
    rm -f "${home}/Desktop/Project X.desktop" 2>/dev/null || true
}

launch_application() {
    user="$1"
    if command -v runuser >/dev/null 2>&1; then
        runuser -u "$user" -- /usr/bin/projectx >/dev/null 2>&1 &
        return 0
    fi
    su - "$user" -c 'nohup /usr/bin/projectx >/dev/null 2>&1 &' 2>/dev/null || true
}

case "$1" in
    configure)
        chmod +x /opt/projectx/projectx /usr/bin/projectx 2>/dev/null || true
        refresh_desktop_integration

        if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
            mkdir -p /var/lib/projectx
            echo "$SUDO_USER" > /var/lib/projectx/install-user
            chmod 644 /var/lib/projectx/install-user

            if desktop_shortcut_enabled; then
                create_desktop_shortcut "$SUDO_USER"
            fi
            if launch_after_install_enabled; then
                launch_application "$SUDO_USER"
            fi
        fi
        ;;
esac

if db_stop 2>/dev/null; then
    :
fi

exit 0
