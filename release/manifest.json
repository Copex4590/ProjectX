      "architecture": "x86_64",
      "checksum_file": "SHA256SUMS"
    },
    "linux": {
      "primary": {
        "file": "ProjectX.deb",
        "directory": "release/linux",
        "website_directory": "website/downloads/linux",
        "format": "Debian package",
        "architecture": "amd64",
        "checksum_file": "SHA256SUMS"
      },
      "secondary": {
        "file": "ProjectX.AppImage",
        "directory": "release/linux",
        "website_directory": "website/downloads/linux",
        "format": "AppImage (portable)",
        "architecture": "x86_64",
        "checksum_file": "SHA256SUMS"
      }
    }
  },
  "checksum_files": [
    "release/linux/SHA256SUMS",
    "release/windows/SHA256SUMS"
  ],
  "release_notes": [
