  "status": "Alpha — First Public Test",
  "github": "https://github.com/Copex4590/ProjectX",
  "build": {
    "python_version": "3.10+",
    "python_used_for_build": "3.12"
  },
  "minimum_os": {
    "windows": "Windows 10 x64 or later",
    "linux": "Linux Mint 21+ / Ubuntu 22.04+ x86_64 (glibc)"
  },
  "packages": {
    "windows": {
      "file": "ProjectX-Setup.exe",
      "directory": "release/windows",
